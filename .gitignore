# The workspace/ dir itself is committed (other users need it; it's the designated working area),
# but per-target artifacts inside it (APK/.so/plaintext traffic) are NOT — only sanitized cases/ are.
workspace/*
!workspace/README.md

# Machine-specific / generated
config/local.yaml
.mcp.json
*.log

# Scratch / planning notes (not committed)
tmp/

# MCP server runtime workspaces (regenerated at runtime; not committed)
apktool_mcp_server_workspace/

# python / node
.venv/
venv/
__pycache__/
*.pyc
node_modules/

# Large tool binaries (downloaded by the setup script per registry.yaml; not committed)
tools/bin/
*.apk
*.aab
*.xapk
*.so
*.jar
!**/apktool*.jar

# js-trace-engine generated output
jt-out/
skills/web/js-trace-engine/test/out*/
skills/web/js-trace-engine/native/quickjs/quickjs/

# Session secrets — captured cookies/tokens used by case reproduction scripts (NEVER commit)
.cookies.json
*.cookies.json
cookies.json
