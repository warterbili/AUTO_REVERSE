{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "auto_reverse/meta.schema.json",
  "title": "Phase 0 — Intake meta.json",
  "type": "object",
  "required": ["target", "type", "timestamp"],
  "additionalProperties": true,
  "properties": {
    "target": {"type": "string", "description": "package id / URL / file name of the target"},
    "type": {"enum": ["android", "ios", "web", "windows", "native"]},
    "timestamp": {"type": "string", "description": "ISO-8601 acquisition time"},
    "operator": {"type": "string"},
    "source": {"type": "string", "description": "how the target was acquired: device | local | apkpure | url | ..."},
    "files": {"type": "array", "items": {"type": "string"}, "description": "acquired files (base.apk, splits, ...)"}
  }
}
