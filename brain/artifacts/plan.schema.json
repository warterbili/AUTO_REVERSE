{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "auto_reverse/plan.schema.json",
  "title": "Phase 2 — plan.json",
  "type": "object",
  "required": ["phase", "playbook", "tasks"],
  "additionalProperties": true,
  "properties": {
    "phase": {"const": "plan"},
    "playbook": {"type": "string", "description": "the brain/playbooks/<name> selected from the fingerprint"},
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["question", "use", "expect"],
        "properties": {
          "question": {"type": "string", "description": "the concrete question this task answers"},
          "use": {"type": "string", "description": "the skill / adapter / tool to use"},
          "expect": {"type": "string", "description": "the artifact or evidence this task should produce"}
        }
      }
    }
  }
}
