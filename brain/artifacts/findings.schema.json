{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "auto_reverse/findings.schema.json",
  "title": "Phases 3-5 — uniform findings.json (static / dynamic / native)",
  "type": "object",
  "required": ["phase", "status", "findings", "open_questions"],
  "additionalProperties": true,
  "properties": {
    "phase": {"enum": ["static", "dynamic", "native"]},
    "status": {"enum": ["ok", "partial", "blocked"]},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "detail", "evidence"],
        "properties": {
          "type": {"enum": ["endpoint", "crypto_site", "param", "algorithm", "constant", "native_boundary", "other"]},
          "detail": {"type": "string"},
          "evidence": {"type": "string", "description": "file:line / pid / ghidra addr — must be reproducible"}
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": {"type": "string"},
      "description": "unresolved encrypted fields / unknown calls that drive the next phase"
    },
    "next_suggested": {"type": "string", "description": "the next phase or skill to run"}
  }
}
